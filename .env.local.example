# --- Attribution pipeline -------------------------------------------------

# The Tetra brand website (course site). Used for the dashboard "Ver site"
# link and as the destination of the /r/{slug} referral redirect.
NEXT_PUBLIC_SITE_URL=https://tetraeducacao.com.br

# Base URL the partner-facing referral links are built from (lib/links.ts).
# Point this at THIS portal's /r so clicks are recorded before redirecting:
#   https://<your-portal-domain>/r
# (Optional: serve them on the brand domain with a Vercel rewrite
#  tetraeducacao.com.br/r/:slug -> <portal>/r/:slug — see docs/website-integration.md)
NEXT_PUBLIC_REFERRAL_BASE_URL=https://tetraeducacao.com.br/r

# Shared secret the brand site sends as `x-tetra-ingest-key` when calling
# /api/track/lead and /api/track/conversion. Generate a long random string
# (e.g. `openssl rand -hex 32`) and set the SAME value in the website project.
# Without this set, ingestion is closed (returns 401).
TETRA_INGEST_KEY=
